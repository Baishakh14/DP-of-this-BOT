#include<bits/stdc++.h>
#include<ext/pb_ds/assoc_container.hpp>
#include<ext/pb_ds/tree_policy.hpp>
using namespace std;
using namespace __gnu_pbds;
typedef tree<int, null_type, less<int>, rb_tree_tag, tree_order_statistics_node_update> pbds;
#define ll long long
const int mod = 1e9+7;
// s.order_of_key(x) -> values total are small than x
// *s.find_by_order(x)  -> kth small elemnt (index) in pbds
int dp[11][100][100][2];/// pos, sum%k, digsum%k, tight
string s;
int k;
int find(int pos,int sum,int ds,int tight)
{
    if(pos == s.size()) 
    {
        if(sum == ds && ds == 0) return 1;
        else return 0;
    }
    int val = dp[pos][sum][ds][tight];
    if(val != -1) return val;
    int lim = (tight == 1 ? s[pos] - '0' : 9);
    int ans = 0;
    for(int i = 0;i<=lim;i++)
    {
        int ns = (sum * 10 + i) % k;
        int nds = (ds + i) % k;
        int nt = ((tight == 1) && (i == lim));
        ans += find(pos+1,ns,nds,nt);
    }
    return dp[pos][sum][ds][tight] = ans;
}
int main()
{
    int t;
    cin>>t;
    int i = 0;
    while(t--)
    {
        int l,r;
        cin>>l>>r>>k;
        if(k > 90) 
        {
            cout<<"Case "<<++i<<": "<<0<<endl;
            continue;
        }
        memset(dp,-1,sizeof(dp));
        s = to_string(r);
        int ans = find(0,0,0,1);
        s.clear();
        memset(dp,-1,sizeof(dp));
        s = to_string(l-1);
        ans -= find(0,0,0,1);
        cout<<"Case "<<++i<<": "<<ans<<endl;
    }
  return 0;
}


